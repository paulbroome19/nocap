# Copy to .env for local development. Never commit real secrets.
# Twelve-factor: the app reads all configuration from the environment.

APP_NAME=NoCap
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Local Postgres (SQLAlchemy 2.x + psycopg v3 driver).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/nocap

# Where uploaded DPM snapshots are stored on disk (one subdir per snapshot id).
DATA_DIR=./data

# mdbtools binaries used to convert the EBA DPM Access (.accdb) release to SQLite
# on ingest. Override if not on PATH.
MDB_SCHEMA_BIN=mdb-schema
MDB_EXPORT_BIN=mdb-export
